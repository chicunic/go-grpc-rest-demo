{
  "mcpServers": {
    "cloud-run": {
      "type": "stdio",
      "command": "npx",
      "args": ["-y", "@google-cloud/cloud-run-mcp"]
    },
    "gcloud": {
      "type": "stdio",
      "command": "npx",
      "args": ["-y", "@google-cloud/gcloud-mcp"]
    },
    "gemini-cloud-assist": {
      "type": "stdio",
      "command": "npx",
      "args": ["-y", "@google-cloud/gemini-cloud-assist-mcp@latest"],
      "timeout": 600000
    },
    "observability": {
      "type": "stdio",
      "command": "npx",
      "args": ["-y", "@google-cloud/observability-mcp"]
    },
    "go-dev-mcp": {
      "type": "stdio",
      "command": "godevmcp",
      "args": ["serve"]
    }
  }
}
